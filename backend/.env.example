PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webxemphim?schema=public"
JWT_ACCESS_SECRET="your-super-secret-access-token-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-this"
CLIENT_URL="http://localhost:3000"
KKPHIM_API_URL="https://phimapi.com"
COOKIE_SECURE=false
# Optional one-time bootstrap account. Use a unique password of 12+ characters.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_USERNAME=admin
VIP_PAYMENT_MODE=manual
# Choose Brevo HTTPS API, Resend, or SMTP. Brevo works on hosts that block SMTP ports.
BREVO_API_KEY=
RESEND_API_KEY=
MAIL_FROM="CINE3D <no-reply@example.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
PUBLIC_API_URL=http://localhost:5000/api
PASSWORD_RESET_URL=http://localhost:3000/account
REQUIRE_EMAIL_VERIFICATION=false
# Web OAuth client ID (legacy single-audience setting).
GOOGLE_CLIENT_ID=
# Comma-separated Google OAuth client IDs accepted by the backend.
GOOGLE_CLIENT_IDS=
GOOGLE_ANDROID_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v24.0
TURNSTILE_SECRET_KEY=
# Interim native attestation shared secret. Must match the mobile app
# EXPO_PUBLIC_APP_ATTESTATION_TOKEN. Native clients send it as X-App-Attestation
# and skip Cloudflare Turnstile. If unset, native auth is allowed in open
# migration mode (logged as a warning). Replace with Play Integrity before
# treating this as a real security boundary.
MOBILE_APP_ATTESTATION_TOKEN=
MOBILE_EMAIL_VERIFIED_DEEP_LINK="cine3d://account?verified=success"
WATCH_ROOM_TTL_MS=1800000
WATCH_ROOM_MAX_USERS=20
WATCH_ROOM_TOKEN_SECRET=
# Optional browser push notifications. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@example.com"
ANALYTICS_RETENTION_DAYS=90
# Native Firebase Cloud Messaging. Keep the JSON server-side and never commit it.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Native download authorization lifetime (60-86400 seconds).
DOWNLOAD_ENTITLEMENT_TTL_SECONDS=900
# Google Play Developer API service account and Android application package.
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# JSON object mapping Play product IDs to an active VipPlan id or code.
PLAY_PRODUCT_PLAN_MAP='{"cine3d.vip.monthly":"VIP_MONTHLY"}'
GOOGLE_PLAY_ACKNOWLEDGE_PURCHASES=true
# Secret/header applied by the trusted RTDN relay or push subscription.
GOOGLE_PLAY_RTDN_SECRET=
GOOGLE_PLAY_RTDN_SECRET_HEADER=X-Google-RTDN-Secret
