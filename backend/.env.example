PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webxemphim?schema=public"
JWT_ACCESS_SECRET="your-super-secret-access-token-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-this"
CLIENT_URL="http://localhost:3000"
KKPHIM_API_URL="https://phimapi.com"
COOKIE_SECURE=false
# Optional one-time bootstrap account. Use a unique password of 12+ characters.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_USERNAME=admin
VIP_PAYMENT_MODE=manual
# Choose Brevo HTTPS API, Resend, or SMTP. Brevo works on hosts that block SMTP ports.
BREVO_API_KEY=
RESEND_API_KEY=
MAIL_FROM="CINE3D <no-reply@example.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
PUBLIC_API_URL=http://localhost:5000/api
PASSWORD_RESET_URL=http://localhost:3000/account
REQUIRE_EMAIL_VERIFICATION=false
GOOGLE_CLIENT_ID=
TURNSTILE_SECRET_KEY=
WATCH_ROOM_TTL_MS=1800000
WATCH_ROOM_MAX_USERS=20
# Optional browser push notifications. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@example.com"
ANALYTICS_RETENTION_DAYS=90
