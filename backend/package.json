{
  "name": "webxemphim-backend",
  "version": "1.0.0",
  "description": "Backend API for 3D Cinematic Movie Streaming platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.js",
    "start": "npm run prisma:deploy && npm run prisma:seed && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "node scripts/deploy-db.js",
    "prisma:seed": "prisma db seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^8.0.1",
    "@types/web-push": "^3.6.4",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^14.2.0",
    "google-auth-library": "^10.9.0",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "prisma": "^5.12.1",
    "redis": "^5.0.0",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  }
