datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique // e.g. "USER", "ADMIN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  googleId                 String?   @unique
  username                 String    @unique
  password                 String
  avatar                   String?
  isVerified               Boolean   @default(false)
  isLocked                 Boolean   @default(false)
  isVip                    Boolean   @default(false)
  vipExpiresAt             DateTime?
  playerPreferences        Json?
  passwordResetToken       String?
  passwordResetExpires     DateTime?
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  roleId                   String
  role                     Role      @relation(fields: [roleId], references: [id])
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  comments           Comment[]
  commentLikes       CommentLike[]
  ratings            Rating[]
  favorites          Favorite[]
  watchlist          Watchlist[]
  watchHistory       WatchHistory[]
  notifications      Notification[]
  reports            Report[]
  refreshTokens      RefreshToken[]
  vipOrders          VipOrder[]         @relation("VipOrderUser")
  confirmedVipOrders VipOrder[]         @relation("VipOrderConfirmer")
  movieFollows       MovieFollow[]
  playlists          Playlist[]
  profiles           UserProfile[]
  pushSubscriptions  PushSubscription[]
  analyticsEvents    AnalyticsEvent[]
  avatarBlob         UserAvatar?
  actorFollows       ActorFollow[]
  directorFollows    DirectorFollow[]
  feedbacks          Feedback[]

  @@index([email])
  @@index([username])
  @@index([passwordResetToken])
  @@index([emailVerificationToken])
  @@index([roleId])
  @@index([isVip])
  @@index([vipExpiresAt])
}

model Feedback {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   String
  subject    String
  content    String
  status     String   @default("PENDING")
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([category])
}

model UserAvatar {
  userId    String   @id
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VipPlan {
  id           String     @id @default(uuid())
  code         String     @unique
  name         String
  description  String?
  price        Int
  durationDays Int
  isActive     Boolean    @default(true)
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders       VipOrder[]

  @@index([isActive, displayOrder])
}

model VipOrder {
  id                String    @id @default(uuid())
  orderCode         String    @unique
  userId            String
  user              User      @relation("VipOrderUser", fields: [userId], references: [id], onDelete: Cascade)
  planId            String
  plan              VipPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  amount            Int
  durationDays      Int
  status            String    @default("PENDING")
  provider          String    @default("MANUAL")
  providerReference String?   @unique
  providerOrderCode String?   @unique
  checkoutUrl       String?
  paymentQrCode     String?
  expiresAt         DateTime
  paidAt            DateTime?
  confirmedById     String?
  confirmedBy       User?     @relation("VipOrderConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@index([planId])
  @@index([confirmedById])
}

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movies    Movie[]
}

model Genre {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  movieGenres MovieGenre[]
}

model Actor {
  id          String       @id @default(uuid())
  name        String
  avatarUrl   String?
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  movieActors MovieActor[]
  followers   ActorFollow[]
}

model Director {
  id             String          @id @default(uuid())
  name           String
  avatarUrl      String?
  slug           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  movieDirectors MovieDirector[]
  followers      DirectorFollow[]
}

model ActorFollow {
  id        String   @id @default(uuid())
  userId    String
  actorId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor     Actor    @relation(fields: [actorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, actorId])
  @@index([actorId])
}

model DirectorFollow {
  id         String   @id @default(uuid())
  userId     String
  directorId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  director   Director @relation(fields: [directorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, directorId])
  @@index([directorId])
}

model Movie {
  id                  String    @id @default(uuid())
  title               String
  englishTitle        String?
  slug                String    @unique
  description         String
  backdropUrl         String
  posterUrl           String
  trailerUrl          String?
  releaseYear         Int
  duration            Int // in minutes
  quality             String    @default("HD") // HD, FHD, 2K, 4K
  episodeCount        Int       @default(1)
  isSeries            Boolean   @default(false) // true = series (phim bộ), false = movie (phim lẻ)
  isDubbed            Boolean   @default(false)
  status              String    @default("Completed") // Ongoing, Completed, Upcoming
  views               Int       @default(0)
  ratingAvg           Float     @default(0.0)
  isFeatured          Boolean   @default(false)
  isTrending          Boolean   @default(false)
  isProposed          Boolean   @default(false) // Phim đề xuất
  isVip               Boolean   @default(false)
  vipEarlyAccessUntil DateTime?
  countryId           String
  country             Country   @relation(fields: [countryId], references: [id])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  episodes            Episode[]
  movieActors         MovieActor[]
  movieGenres         MovieGenre[]
  movieDirectors      MovieDirector[]
  ratings             Rating[]
  favorites           Favorite[]
  watchlist           Watchlist[]
  watchHistory        WatchHistory[]
  banners             Banner[]
  reports             Report[]
  followers           MovieFollow[]
  playlistItems       PlaylistItem[]
  profileFavorites    ProfileFavorite[]
  profileWatchlist    ProfileWatchlist[]
  profileWatchHistory ProfileWatchHistory[]

  @@index([slug])
  @@index([title])
  @@index([countryId])
  @@index([createdAt])
  @@index([views])
  @@index([isVip])
  @@index([vipEarlyAccessUntil])
}

model MovieActor {
  id        String   @id @default(uuid())
  movieId   String
  actorId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  actor     Actor    @relation(fields: [actorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movieId, actorId])
  @@index([actorId])
}

model MovieGenre {
  id        String   @id @default(uuid())
  movieId   String
  genreId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre     Genre    @relation(fields: [genreId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movieId, genreId])
  @@index([genreId])
}

model MovieDirector {
  id         String   @id @default(uuid())
  movieId    String
  directorId String
  movie      Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  director   Director @relation(fields: [directorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([movieId, directorId])
  @@index([directorId])
}

model Episode {
  id                String    @id @default(uuid())
  movieId           String
  movie             Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  title             String // e.g. "Tập 1", "Tập 2", "Full"
  episodeOrder      Int // e.g. 1, 2, 3
  seasonNumber      Int       @default(1)
  airDate           DateTime?
  releaseNotifiedAt DateTime?
  introEndSeconds   Int?
  outroStartSeconds Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  videoSources        VideoSource[]
  subtitles           Subtitle[]
  profileWatchHistory ProfileWatchHistory[]

  @@unique([movieId, episodeOrder])
  @@index([movieId, seasonNumber, episodeOrder])
  @@index([airDate])
  @@index([airDate, releaseNotifiedAt])
}

model VideoSource {
  id        String   @id @default(uuid())
  episodeId String
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  server    String   @default("Main Server") // e.g. "Server 1", "Backup Server"
  quality   String   @default("1080p") // 720p, 1080p, 4K
  url       String // HLS link (.m3u8) or MP4 link
  type      String   @default("hls") // hls, mp4
  isPremium Boolean  @default(false)
  healthStatus       String    @default("unknown")
  lastCheckedAt      DateTime?
  lastStatusCode     Int?
  lastResponseTimeMs Int?
  lastError          String?
  consecutiveFailures Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([episodeId])
  @@index([healthStatus, lastCheckedAt])
}

model Subtitle {
  id        String   @id @default(uuid())
  episodeId String
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  language  String // e.g. "Vietnamese", "English"
  url       String // Subtitle file URL (vtt or srt)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([episodeId])
}

model Comment {
  id               String   @id @default(uuid())
  movieId          String
  userId           String
  content          String
  isSpoiler        Boolean  @default(false)
  isPinned         Boolean  @default(false)
  timestampSeconds Int?
  parentId         String? // For threaded replies
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]     @relation("CommentReplies")
  commentLikes CommentLike[]
  reports      Report[]

  @@index([movieId, parentId, isPinned, createdAt])
  @@index([userId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model Rating {
  id        String   @id @default(uuid())
  movieId   String
  userId    String
  score     Int // 1-10 scale
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(uuid())
  movieId   String
  userId    String
  createdAt DateTime @default(now())

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
  @@index([userId, createdAt])
}

model Watchlist {
  id        String   @id @default(uuid())
  movieId   String
  userId    String
  createdAt DateTime @default(now())

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
  @@index([userId, createdAt])
}

model WatchHistory {
  id          String   @id @default(uuid())
  movieId     String
  userId      String
  episodeId   String? // Active episode
  watchedTime Int      @default(0) // Seconds watched
  duration    Int      @default(0) // Episode duration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
  @@index([userId, updatedAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  url       String? // Link path to redirect when clicked
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead, createdAt])
}

model Banner {
  id          String   @id @default(uuid())
  movieId     String
  movie       Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  title       String
  description String
  imageUrl    String // Parallax image url
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([movieId])
  @@index([isActive, order])
}

model Report {
  id        String   @id @default(uuid())
  userId    String
  movieId   String?
  commentId String?
  type      String // e.g. "stream_error", "abusive_comment"
  content   String
  status    String   @default("Pending") // Pending, Resolved, Ignored
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie   Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([movieId])
  @@index([commentId])
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  deviceName String?
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model MovieFollow {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, movieId])
  @@index([movieId, createdAt])
}

model Playlist {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublic    Boolean        @default(false)
  items       PlaylistItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, updatedAt])
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String
  movieId    String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  movie      Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([playlistId, movieId])
  @@index([playlistId, position])
  @@index([movieId])
}

model UserProfile {
  id           String                @id @default(uuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  avatar       String?
  isKids       Boolean               @default(false)
  pinHash      String?
  favorites    ProfileFavorite[]
  watchlist    ProfileWatchlist[]
  watchHistory ProfileWatchHistory[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([userId, createdAt])
}

model ProfileFavorite {
  id        String      @id @default(uuid())
  profileId String
  movieId   String
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  movie     Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([profileId, movieId])
  @@index([profileId, createdAt])
}

model ProfileWatchlist {
  id        String      @id @default(uuid())
  profileId String
  movieId   String
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  movie     Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([profileId, movieId])
  @@index([profileId, createdAt])
}

model ProfileWatchHistory {
  id          String      @id @default(uuid())
  profileId   String
  movieId     String
  episodeId   String?
  watchedTime Int         @default(0)
  duration    Int         @default(0)
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  movie       Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episode     Episode?    @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([profileId, movieId])
  @@index([profileId, updatedAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  path      String?
  movieId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([movieId, createdAt])
}
