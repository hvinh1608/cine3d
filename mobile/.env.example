EXPO_PUBLIC_API_URL=https://api.cine3d.id.vn/api
# Web OAuth client ID. Must also be listed in GOOGLE_CLIENT_ID(S) on the backend.
# Create a separate Android OAuth client for vn.cine3d.app with the app signing SHA-1.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Current backend native contract accepts this header. A static bundled value is extractable;
# replace with Play Integrity/App Attest before treating it as a security boundary.
EXPO_PUBLIC_APP_ATTESTATION_TOKEN=
# Also add google-services.json (Android) / GoogleService-Info.plist (iOS) to the native build.
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# Comma-separated Google Play subscription IDs.
EXPO_PUBLIC_GOOGLE_PLAY_PRODUCT_IDS=vn.cine3d.vip_monthly,vn.cine3d.vip_quarterly,vn.cine3d.vip_yearly
