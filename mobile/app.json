{
  "expo": {
    "name": "Cine3D",
    "slug": "cine3d",
    "version": "1.0.12",
    "orientation": "default",
    "scheme": "cine3d",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vn.cine3d.app",
      "associatedDomains": [
        "applinks:cine3d.id.vn"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to protect your Cine3D account.",
        "NSCameraUsageDescription": "Cine3D cần camera để quét mã QR đăng nhập web."
      }
    },
    "android": {
      "package": "vn.cine3d.app",
      "versionCode": 12,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.WRITE_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#09090B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/search"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/the-loai/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/quoc-gia/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/nam/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/schedule"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/actors/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/directors/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/movies/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/watch/"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "path": "/watch-together"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/watch-together/rooms"
            },
            {
              "scheme": "https",
              "host": "cine3d.id.vn",
              "pathPrefix": "/qr-login"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": false,
          "faceIDPermission": "Use Face ID to protect your Cine3D account."
        }
      ],
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#09090B",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#09090B"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#E50914",
          "defaultChannel": "general"
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to protect your Cine3D account."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-iap",
      [
        "expo-camera",
        {
          "cameraPermission": "Cine3D cần camera để quét mã QR đăng nhập web.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "extra": {
      "player": {
        "defaultOrientation": "portrait",
        "supportsFullscreenLandscape": true
      }
    }
  }
}
